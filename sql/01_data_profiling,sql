-- 1. TABLE INVENTORY AND ROW COUNTS

select 'branches' as table_name, count(*) as row_count from branches
union all
select 'customers' as table_name, count(*) as row_count from customers
union all
select 'accounts' as table_name, count(*) as row_count from accounts
union all
select 'cards' as table_name, count(*) as row_count from cards
union all
select 'loans' as table_name, count(*) as row_count from loans
union all
select 'loan_payments' as table_name, count(*) as row_count from loan_payments
union all
select 'transactions' as table_name, count(*) as row_count from transactions
union all
select 'fraud_alerts' as table_name, count(*) as row_count from fraud_alerts
union all
select 'customer_contacts' as table_name, count(*) as row_count from customer_contacts
union all
select 'dataset_metadata' as table_name, count(*) as row_count from dataset_metadata
order by row_count desc;


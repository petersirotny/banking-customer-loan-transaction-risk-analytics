-- 5. DUPLICATE CUSTOMER IDs

select
	customer_id,
	count(*) as occurrence_count,
	min(customer_since) as first_customer_since,
	max(customer_since) as last_customer_since
from
	customers
where
	customer_id is not null
group by
	customer_id
having
	count(*) > 1
order by
	occurrence_count desc,
	customer_id;